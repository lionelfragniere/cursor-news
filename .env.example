CURSOR_NEWS_HOME=.

# LAN web server
CURSOR_NEWS_HOST=0.0.0.0
CURSOR_NEWS_PORT=8000

# Pipeline
CURSOR_NEWS_TIMEZONE=Europe/Zurich
CURSOR_NEWS_BUFFER_SLOTS=6
CURSOR_NEWS_MAX_ARTICLES=8
CURSOR_NEWS_INGEST_INTERVAL_MINUTES=5
CURSOR_NEWS_GENERATE_INTERVAL_SECONDS=60

# Local LLM
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:14b

# TTS
TTS_ENGINE=edge
# Voix feminine francaise en ligne gratuite via Microsoft Edge TTS.
EDGE_TTS_VOICE=fr-CH-ArianeNeural
EDGE_TTS_RATE=-5%
# Fallback local Piper.
TTS_MODEL_NAME=models\piper\fr_FR-siwis-medium\fr_FR-siwis-medium.onnx
# Coqui reste disponible en alternative:
COQUI_MODEL_NAME=tts_models/fr/css10/vits
COQUI_DEVICE=cpu
# COQUI_SPEAKER_WAV=C:\path\to\voice_sample.wav
# COQUI_SPEAKER=

# Audio encoding
# Empty = use ffmpeg from PATH. Windows local setup can use tools\ffmpeg\bin\ffmpeg.exe.
FFMPEG_PATH=
ALLOW_WAV_FALLBACK=0

# Infomaniak is dry-run only in v1
INFOMANIAK_DRY_RUN=1
INFOMANIAK_API_BASE=https://api.infomaniak.com
INFOMANIAK_TOKEN=
INFOMANIAK_METADATA_URL=https://api.infomaniak.com/1/radios/stats/metadata
INFOMANIAK_METADATA_USERNAME=
INFOMANIAK_METADATA_PASSWORD=
INFOMANIAK_METADATA_TEMPLATE={artist} - {title}

# GCP publishing
GCP_PROJECT_ID=cursor-news-radio-20260517
GCP_BUCKET=gs://cursor-news-radio-20260517-audio
GCP_PUBLIC_BASE_URL=https://storage.googleapis.com/cursor-news-radio-20260517-audio
GCLOUD_PATH=gcloud
